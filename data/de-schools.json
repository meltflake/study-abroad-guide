    "desc": {
      "en": "Germany's top technical university. Nearly free tuition (~€300/year admin fee). World-class engineering and CS.",
      "zh": "德国顶尖理工大学，学费几乎免费（约€300/年管理费），工程和CS世界一流。"
    },
    "climate": {
      "zh": "慕尼黑大陆性气候。夏季温暖（18-25°C），冬季寒冷有雪（-3至3°C）。阿尔卑斯山南风偶带暖流。",
      "en": "Munich has a continental climate. Summers warm (18-25°C), winters cold with snow (-3 to 3°C). Occasional warm Alpine south winds (Föhn)."
    },
    "housing": {
      "zh": "Studentenwerk提供宿舍约€300-500/月，名额紧张。校外合租€500-800/月。建议提前6个月申请。",
      "en": "Studentenwerk dorms €300-500/month, limited spots. Off-campus shared flats €500-800/month. Apply 6 months in advance."
    },
    "employment": {
      "zh": "慕尼黑是德国经济引擎，BMW、西门子、安联等总部所在地。工科毕业生极受欢迎。18个月求职签证。",
      "en": "Munich is Germany's economic powerhouse—home to BMW, Siemens, Allianz. Engineering graduates in high demand. 18-month job-seeking visa."
    },
    "healthcare": {
      "zh": "德国强制医疗保险。公立保险约€110/月（学生费率），覆盖全面。大学有Studentenwerk健康咨询。",
      "en": "Germany mandates health insurance. Public insurance ~€110/month (student rate), comprehensive coverage. University health counseling available."
    },
    "application": {
      "zh": "通过uni-assist或学校官网申请。需高中成绩单、德语/英语证明、APS审核（部分国家）。",
      "en": "Apply via uni-assist or university website. Transcripts, German/English proficiency, APS certification (some countries) required."
    },
    "safetyDetail": {
      "zh": "慕尼黑是德国最安全的大城市之一，犯罪率低。校园和公共区域安保良好。",
      "en": "Munich is one of Germany's safest major cities with low crime rate. Good security on campus and in public areas."
    },
    "deadline": {
      "zh": "冬季学期（10月开学）：7月15日；夏季学期（4月开学）：1月15日",
      "en": "Winter semester (Oct start): Jul 15; Summer semester (Apr start): Jan 15"
    }
  },
